{
  "name": "Better Pivot",
  "description": "A Chrome Extension to enhance the Pivot experience",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "",
    "default_icon": "hitplay.png"
  },
  "content_scripts": [
    {
      "matches": ["https://app.pivotnow.io/*"],
      "js": ["scripts/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://app.pivotnow.io/*"],
      "js": ["scripts/xlsx.full.min.js", "scripts/back.js"],
      "world": "ISOLATED"
    },
    {
      "matches": ["https://app.pivotnow.io/*"],
      "js": ["scripts/tableresize.js"],
      "world": "MAIN",
      "run_at":"document_end"
    }
  ],
  "icons": {
    "16": "hitplay.png",
    "32": "hitplay.png",
    "48": "hitplay.png",
    "128": "hitplay.png"
  }
}