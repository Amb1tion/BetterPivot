{
  "name": "Better Pivot",
  "description": "A Chrome Extension to enhance Pivot experience",
  "version": "1.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "hello.html",
    "default_icon": "hello_extensions.png"
  },
  "content_scripts": [
    {
      "matches": ["https://app.pivotnow.io/*"],
      "js": ["scripts/interceptor.js"],
      "world": "MAIN",
      "run_at": "document_start"
    },
    {
      "matches": ["https://app.pivotnow.io/*"],
      "js": ["scripts/back.js"],
      "world": "ISOLATED"
    }
  ]
}